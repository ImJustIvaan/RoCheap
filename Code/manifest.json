{
  "manifest_version": 3,
  "name": "RoCheap - 40% Off",
  "version": "1.5",
  "permissions": ["storage", "scripting", "activeTab", "tabs"],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": { 
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.roblox.com/catalog/*",
        "https://www.roblox.com/bundles/*",
        "https://www.roblox.com/game-pass/*"
      ],
      "js": ["content.js"]
    }
  ],
  "background": { 
    "service_worker": "background.js" 
  }
}